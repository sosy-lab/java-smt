<!-- vim: set tabstop=8 shiftwidth=4 expandtab filetype=ant : -->
<project name="maven-central-publish" basedir="."
         xmlns:ivy="antlib:org.apache.ivy.ant">

    <!--
        This file provides targets to publish artifacts from the Ivy repository
        to Maven Central via the new Sonatype Central Publishing Portal (central.sonatype.com).

        The script loads artifacts directly from Ivy, generates a POM file,
        then uploads to the Maven staging server.
        There is a manually triggered release process via https://central.sonatype.com/ .

        Locally, we use the dist-directory for temporary storage.
        When debugging, you can check that location for files and file-structure.

        Prerequisites for publishing:
        1. Account:
           Register at https://central.sonatype.com/ and ensure you have access to the
           'org.sosy-lab' namespace.
        2. PGP Key:
           - You need a GPG key pair (RSA 2048-bit or higher).
           - Your public key MUST be published to a supported keyserver:
             e.g., 'gpg - -keyserver keyserver.ubuntu.com - -send-keys <KEY_ID>'
           - The passphrase can be provided via '-Dgpg.passphrase=...' or in build.properties.
        3. Authentication Token:
           - Log in to https://central.sonatype.com/, go to 'Account', and 'Generate User Token'.
           - Add the credentials to your '~/.m2/settings.xml' as follows:
             <server>
               <id>SonatypeCentral</id>
               <username>TOKEN_NAME</username>
               <password>TOKEN_PASSWORD</password>
             </server>

        Usage:
          ant publish-to-maven-central -Dpublish.component=javasmt-solver-z3 -Dpublish.version=4.16.0
          ant publish-to-maven-central -Dpublish.component=javasmt-yices2 -Dpublish.version=6.0.0-141-g04134287c
          ant publish-to-maven-central -Dpublish.component=java-smt -Dpublish.version=5.0.0

        For testing without upload, add option '-Dpublish.upload=false'.
        Additionally, we provide a script for testing and debugging the bundle process:
          scripts/test-maven-central-bundle.sh

        Finalizing Publication:
        1. Review and Publish:
           - Log in to https://central.sonatype.com/publishing/deployments.
           - Check that the deployment is validated and contains all expected files.
           - Click 'Publish' to start the release process.
        2. Wait for Sync:
           - It usually takes about 15-30 minutes for the artifacts to appear in
             Maven Central (https://repo1.maven.org/maven2/org/sosy-lab/).
             Applications can then download the artifacts using the specified version.
           - Search results on https://central.sonatype.com/ might take longer to update.
    -->

    <import file="build-ivy.xml"/>

    <property name="bundle.main.dir" value="dist/maven-central-bundle"/>
    <property name="gpg.passphrase" value=""/>
    <property name="publish.upload" value="true"/>

    <target name="init-maven-central" depends="load-ivy">
        <fail message="Please provide -Dpublish.component (e.g., javasmt-solver-z3, javasmt-yices2, java-smt)">
            <condition><not><isset property="publish.component"/></not></condition>
        </fail>
        <fail message="Please provide -Dpublish.version (e.g., 4.12.2)">
            <condition><not><isset property="publish.version"/></not></condition>
        </fail>

        <property name="publish.full-name" value="${publish.component}"/>
        <property name="bundle.rel.dir" value="org/sosy-lab/${publish.full-name}/${publish.version}"/>
        <property name="bundle.dir" value="${bundle.main.dir}/${bundle.rel.dir}"/>
        <property name="zip.file" value="${bundle.main.dir}/${publish.component}-${publish.version}-bundle.zip"/>
        <property name="ivy.resolved.file" value="${bundle.main.dir}/org.sosy_lab-${publish.full-name}-ivy-${publish.version}.xml"/>

        <condition property="is-javasmt" value="true">
            <equals arg1="${publish.component}" arg2="java-smt"/>
        </condition>
        <condition property="is-solver" value="true">
            <matches string="${publish.component}" pattern="^javasmt-solver-.*"/>
        </condition>
        <echo message="Publishing component: ${publish.full-name} ${publish.version} (is solver: ${is-solver})"/>

        <!--
            Get POM template for publication.
            Each component can have a different metadata, license, authors,... -->
        <condition property="pom.template"
                   value="solvers_maven_conf/maven_${publish.component}_pom_template.xml"
                   else="pom_template.xml">
            <equals arg1="${publish.component}" arg2="javasmt-yices2"/>
        </condition>
        <loadresource property="publish.short-name">
            <string value="${publish.component}"/>
            <filterchain>
                <replaceregex pattern="^javasmt-solver-(.*)" replace="\1"/>
            </filterchain>
        </loadresource>
        <condition property="pom.template"
                   value="solvers_maven_conf/maven_${publish.short-name}_pom_template.xml">
            <istrue value="${is-solver}"/>
        </condition>
        <property name="pom.template" value="pom_template.xml"/>

        <!-- Setup properties for POM generation -->
        <property name="ivy.pom.version" value="${publish.version}"/>
        <property name="ivy.pom.groupId" value="org.sosy-lab"/>
        <property name="ivy.pom.artifactId" value="${publish.full-name}"/>
        <property name="ivy.pom.packaging" value="jar"/>
        <property name="ivy.pom.name" value="${publish.full-name}"/>
        <property name="ivy.pom.description" value="JavaSMT component ${publish.full-name}"/>
        <property name="ivy.pom.url" value="https://github.com/sosy-lab/java-smt"/>

        <condition property="isWindows">
            <os family="windows"/>
        </condition>
        <condition property="publish.upload.enabled">
            <istrue value="${publish.upload}"/>
        </condition>
    </target>

    <target name="resolve-from-ivy" depends="init-maven-central" description="Resolve and retrieve artifacts from Ivy repository">
        <delete dir="${bundle.dir}"/>
        <mkdir dir="${bundle.dir}"/>

        <!--
            Download the ivy.xml file from the repository to ensure that the dependencies
            and their versions are correctly reflected in the generated POM.
            We store it outside the bundle directory so it is not included in the ZIP.
        -->
        <echo message="Downloading ivy.xml from ${ivy.repo.url}..."/>
        <get src="${ivy.repo.url}/org.sosy_lab/${publish.full-name}/ivy-${publish.version}.xml"
             dest="${ivy.resolved.file}"/>

        <!-- Load properties from the downloaded ivy.xml -->
        <xmlproperty file="${ivy.resolved.file}" prefix="ivyxml" collapseAttributes="true" keepRoot="false"/>

        <!--
            Determine the mapping configuration.
            (Native) Solvers are artifacts that have no further dependencies.
            We will not use map configuration 'defaultconf' from ivy.xml for solvers,
            but instead include all artifact files, as the user needs to specify them separately anyway.
        -->
        <condition property="pom.mapping.conf" value="*">
            <istrue value="${is-solver}"/>
        </condition>
        <condition property="pom.mapping.conf" value="*">
            <istrue value="${is-javasmt}"/>
        </condition>
        <condition property="pom.mapping.conf" value="${ivyxml.publications.defaultconf}">
            <isset property="ivyxml.publications.defaultconf"/>
        </condition>
        <property name="pom.mapping.conf" value="*"/>
        <echo message="Available Ivy configurations: ${ivyxml.configurations.conf.name}"/>
        <echo message="Default Ivy configuration: ${ivyxml.publications.defaultconf}"/>
        <echo message="Using POM mapping configuration: ${pom.mapping.conf}"/>

        <!-- determine the resolve configurations: use mapping configuration and optionally include 'sources' if available -->
        <condition property="has-sources">
            <contains string=",${ivyxml.configurations.conf.name}," substring=",sources,"/>
        </condition>
        <condition property="resolve.confs" value="*">
            <istrue value="${is-solver}"/>
        </condition>
        <condition property="resolve.confs" value="core,sources">
            <istrue value="${is-javasmt}"/>
        </condition>
        <condition property="resolve.confs" value="${pom.mapping.conf},sources">
            <isset property="has-sources"/>
        </condition>
        <property name="resolve.confs" value="${pom.mapping.conf}"/>
        <echo message="Using resolution configurations: ${resolve.confs}"/>

        <antcall target="resolve-and-retrieve-inline"/>
        <antcall target="resolve-and-retrieve-local"/>
    </target>

    <target name="resolve-and-retrieve-inline" unless="is-javasmt">
        <echo message="Resolving ${publish.full-name} version ${publish.version} from Ivy..."/>
        <ivy:resolve organisation="org.sosy_lab"
                     module="${publish.full-name}"
                     revision="${publish.version}"
                     conf="${resolve.confs}"
                     log="download-only"
                     inline="true"
                     keep="true"
                     transitive="false"/>

        <ivy:retrieve sync="true"
                      overwriteMode="different"
                      pattern="${bundle.dir}/[module]-[revision](-[classifier]).[ext]"
                      conf="${resolve.confs}"
                      type="jar,source,javadoc"/>
        <ivy:retrieve sync="false"
                      overwriteMode="different"
                      pattern="${bundle.dir}/[module]-[revision]-[artifact](-[arch])(-[classifier]).[ext]"
                      conf="${resolve.confs}"
                      type="shared-object,dll,dylib"/>
    </target>

    <target name="resolve-and-retrieve-local" if="is-javasmt">
        <echo message="Resolving ${publish.full-name} version ${publish.version} from local ivy.xml..."/>
        <ivy:resolve file="${ivy.resolved.file}"
                     conf="${resolve.confs}"
                     log="download-only"
                     transitive="false"/>

        <!--
            For java-smt, we download artifacts manually because 'ivy:retrieve'
            does not easily support retrieving artifacts of the module itself
            when resolved via 'file' attribute, and 'core' is private in the ivy-xml.
        -->
        <get src="${ivy.repo.url}/org.sosy_lab/${publish.full-name}/${publish.full-name}-${publish.version}.jar"
             dest="${bundle.dir}/${publish.full-name}-${publish.version}.jar"/>
        <get src="${ivy.repo.url}/org.sosy_lab/${publish.full-name}/${publish.full-name}-${publish.version}-sources.jar"
             dest="${bundle.dir}/${publish.full-name}-${publish.version}-sources.jar"/>
    </target>

    <target name="bundle" depends="init-maven-central" description="Generate POM, sign artifacts, and create ZIP bundle">
        <!-- Generate POM -->
        <echo message="Generating POM for ${publish.full-name} using POM template: ${pom.template}"/>
        <echo message="Apply mapping for configuration: '${resolve.confs}' -> scope 'compile'"/>

        <!-- set version placeholder in the template -->
        <property name="stage.revision" value="${publish.version}"/>
        <property name="bundle.pom.file" value="${bundle.dir}/${publish.full-name}-${publish.version}.pom"/>

        <!--
            The makepom task generates a POM file based on the resolved Ivy dependencies and
            the provided template. We use wildcard '*' for conf to include all dependencies, and
            then specify the mapping for the configurations we want to include.

            It is unclear how Ivy handles multiple configurations with overlapping artifacts,
            but the result is valid: All solver-independent artifacts are included with scope
            'compile' and all solver-related artifacts are included as well with scope 'optional'.
            This approach works well for publishing JavaSMT and also for JavaSMT-Yices2.
        -->
        <ivy:makepom ivyfile="${ivy.resolved.file}"
                     pomfile="${bundle.pom.file}"
                     templatefile="${pom.template}"
                     conf="*">
            <mapping conf="${resolve.confs}" scope="compile"/>
        </ivy:makepom>

        <!-- Maven group is "sosy-lab", not "sosy_lab" in generated POM -->
        <replace file="${bundle.pom.file}">
            <replacetoken>sosy_lab</replacetoken>
            <replacevalue>sosy-lab</replacevalue>
        </replace>

        <!-- Sign all files -->
        <echo message="Signing all artifacts in ${bundle.dir}..."/>
        <apply executable="gpg" failonerror="true">
            <arg value="--detach-sign"/>
            <arg value="--armor"/>
            <arg value="--batch"/>
            <arg value="--no-tty"/>
            <arg value="--pinentry-mode"/>
            <arg value="loopback"/>
            <arg value="--passphrase"/>
            <arg value="${gpg.passphrase}"/>
            <fileset dir="${bundle.dir}">
                <include name="*"/>
            </fileset>
        </apply>

        <!-- Generate checksums for all artifacts, excluding signature and hash-files. -->
        <echo message="Generating checksums for all artifacts..."/>
        <fileset id="bundle.files" dir="${bundle.dir}" includes="*" excludes="*.asc,*.md5,*.sha*"/>
        <checksum algorithm="MD5" fileext=".md5"><fileset refid="bundle.files"/></checksum>
        <checksum algorithm="SHA-1" fileext=".sha1"><fileset refid="bundle.files"/></checksum>
        <checksum algorithm="SHA-256" fileext=".sha256"><fileset refid="bundle.files"/></checksum>
        <checksum algorithm="SHA-512" fileext=".sha512"><fileset refid="bundle.files"/></checksum>

        <!-- Create ZIP bundle starting from the root of the repository structure -->
        <zip destfile="${zip.file}">
            <fileset dir="${bundle.main.dir}">
                <include name="${bundle.rel.dir}/**"/>
            </fileset>
        </zip>

        <echo message="Bundle created at ${zip.file}"/>
    </target>

    <!--
        Sonatype Central Token is loaded from ~/.m2/settings.xml from server with id="SonatypeCentral".
        Alternatively, they can be provided via '-Dsonatype.token.username=...' and '-Dsonatype.token.password=...'.
    -->
    <property name="m2.settings.file" value="${home.dir}/.m2/settings.xml"/>
    <available file="${m2.settings.file}" property="m2.settings.available"/>

    <target name="load-sonatype-token" if="m2.settings.available">
        <!-- Use XSLT to extract credentials for 'SonatypeCentral' into a temporary XML -->
        <tempfile property="temp.xslt" prefix="extract-sonatype-credentials" suffix=".xslt" deleteonexit="true"/>
        <echo file="${temp.xslt}"><![CDATA[<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
<xsl:template match="/">
  <server>
    <xsl:for-each select="//*[local-name()='server'][*[local-name()='id']='SonatypeCentral']">
      <username><xsl:value-of select="*[local-name()='username']"/></username>
      <password><xsl:value-of select="*[local-name()='password']"/></password>
    </xsl:for-each>
  </server>
</xsl:template>
</xsl:stylesheet>]]></echo>
        <tempfile property="temp.xml"
                  prefix="maven-settings-temp"
                  suffix=".xml"
                  deleteonexit="true"/>
        <xslt in="${m2.settings.file}" out="${temp.xml}" style="${temp.xslt}"/>
        <xmlproperty file="${temp.xml}" keepRoot="false" prefix="sonatype.token.m2"/>

        <condition property="sonatype.token.username" value="${sonatype.token.m2.username}">
            <isset property="sonatype.token.m2.username"/>
        </condition>
        <condition property="sonatype.token.password" value="${sonatype.token.m2.password}">
            <isset property="sonatype.token.m2.password"/>
        </condition>
    </target>

    <!--
        Use publishingType AUTOMATIC for auto-release.
        Use publishingType USER_MANAGED for automated stating and manual release via website.
    -->
    <property name="sonatype.publishingType" value="USER_MANAGED"/>

    <target name="upload-to-sonatype" depends="init-maven-central, load-sonatype-token" if="publish.upload.enabled" description="Upload the bundle to Sonatype Central">
        <echo message="The bundle is ready at: ${zip.file}"/>

        <!-- Default values if not set by load-sonatype-token or command line -->
        <property name="sonatype.token.username" value=""/>
        <property name="sonatype.token.password" value=""/>
        <condition property="sonatype.auth.available">
            <and>
                <not><equals arg1="${sonatype.token.username}" arg2=""/></not>
                <not><equals arg1="${sonatype.token.password}" arg2=""/></not>
            </and>
        </condition>

        <condition property="sonatype.auth.message" value="Sonatype authentication available." else="Sonatype authentication NOT available.">
            <isset property="sonatype.auth.available"/>
        </condition>
        <echo message="${sonatype.auth.message}"/>

        <antcall target="upload-to-sonatype-auto"/>
        <antcall target="upload-to-sonatype-manual"/>
    </target>

    <target name="upload-to-sonatype-auto" depends="upload-to-sonatype-windows, upload-to-sonatype-unix" if="sonatype.auth.available">
        <echo message="Upload request submitted successfully."/>
        <echo message="Successfully captured ID from upload: ${sonatype.deployment.id}"/>
        <echo message="For review and final release, please visit:"/>
        <echo message="  https://central.sonatype.com/publishing/deployments/${sonatype.deployment.id}"/>
    </target>

    <target name="upload-to-sonatype-windows" if="isWindows">
        <echo message="Starting upload (Windows)..."/>
        <property name="sonatype.url" value="https://central.sonatype.com/api/v1/publisher/upload?name=${publish.full-name}-${publish.version}&amp;publishingType=${sonatype.publishingType}"/>
        <!-- Use PowerShell for multipart upload on Windows -->
        <exec executable="powershell" failonerror="true" outputproperty="sonatype.deployment.id">
            <arg value="-NoProfile"/>
            <arg value="-Command"/>
            <arg value="$auth = [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes('${sonatype.token.username}:${sonatype.token.password}')); Invoke-RestMethod -Uri '${sonatype.url}' -Method Post -Headers @{ Authorization = 'Basic ' + $auth } -InFile '${zip.file}' -ContentType 'multipart/form-data'"/>
        </exec>
    </target>

    <target name="upload-to-sonatype-unix" unless="isWindows">
        <echo message="Starting upload (Unix)..."/>
        <exec executable="curl" failonerror="true" outputproperty="sonatype.deployment.id">
            <arg value="--no-progress-meter"/>
            <arg value="-X"/>
            <arg value="POST"/>
            <arg value="https://central.sonatype.com/api/v1/publisher/upload?name=${publish.full-name}-${publish.version}&amp;publishingType=${sonatype.publishingType}"/>
            <arg value="-u"/>
            <arg value="${sonatype.token.username}:${sonatype.token.password}"/>
            <arg value="-H"/>
            <arg value="Content-Type: multipart/form-data"/>
            <arg value="-F"/>
            <arg value="bundle=@${zip.file}"/>
        </exec>
    </target>

    <target name="upload-to-sonatype-manual" unless="sonatype.auth.available">
        <echo message="Login to https://central.sonatype.com/ and upload the ZIP file manually."/>
        <echo message="To automate this step, provide options -Dsonatype.token.username and -Dsonatype.token.password, or provide Maven settings."/>
    </target>

    <target name="skip-upload-to-sonatype" depends="init-maven-central" unless="publish.upload.enabled">
        <echo message="Skipping upload to Maven Central as requested."/>
    </target>

    <target name="publish-to-maven-central" depends="resolve-from-ivy, bundle, upload-to-sonatype, skip-upload-to-sonatype"
            description="Complete process to prepare and upload a Maven Central bundle from Ivy"/>
</project>