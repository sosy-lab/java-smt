<!-- vim: set tabstop=8 shiftwidth=4 expandtab sts=4 filetype=ant fdm=marker: -->
<project name="publish-solvers-leansmt" basedir="." xmlns:ivy="antlib:org.apache.ivy.ant">

    <import file="macros.xml"/>

    <property name="leansmt.stageDir" value="build/leansmt-staging/x64"/>
    <property name="leansmt.distDir" value="build/leansmt-dist"/>

    <target name="clean-leansmt-dist">
        <delete dir="${leansmt.distDir}" quiet="true"/>
    </target>

    <target name="package-leansmt" depends="clean-leansmt-dist">
        <fail unless="leansmt.version">
            Please specify the LeanSMT release version with -Dleansmt.version=...
            Example: -Dleansmt.version=0.1.0-lean1
        </fail>
        <available property="leansmt.runtime.available" file="${leansmt.stageDir}/libleansmt_jni.so"/>
        <fail unless="leansmt.runtime.available"
              message="Missing LeanSMT runtime under ${leansmt.stageDir}. Build it first with src/org/sosy_lab/java_smt/solvers/leansmt/README.md."/>

        <mkdir dir="${leansmt.distDir}/x64"/>

        <copy file="${leansmt.stageDir}/libleansmt_jni.so"
              tofile="${leansmt.distDir}/x64/libleansmt_jni-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/libauto_Auto.so"
              tofile="${leansmt.distDir}/x64/libauto_Auto-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/libQq_Qq.so"
              tofile="${leansmt.distDir}/x64/libQq_Qq-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/libsmt_Smt.so"
              tofile="${leansmt.distDir}/x64/libsmt_Smt-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/libsmt_SmtJNI.so"
              tofile="${leansmt.distDir}/x64/libsmt_SmtJNI-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/libcvc5_cvc5.so"
              tofile="${leansmt.distDir}/x64/libcvc5_cvc5-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/libleanshared.so"
              tofile="${leansmt.distDir}/x64/libleanshared-${leansmt.version}.so"/>
        <copy file="${leansmt.stageDir}/cvc5"
              tofile="${leansmt.distDir}/x64/cvc5-${leansmt.version}.bin"/>
    </target>

    <target name="publish-leansmt" depends="package-leansmt, load-ivy"
            description="Publish LeanSMT runtime binaries to Ivy repository.">
        <ivy:resolve conf="solver-leansmt,solver-leansmt-x64" file="solvers_ivy_conf/ivy_leansmt.xml"/>
        <publishToRepository solverName="LeanSMT" solverVersion="${leansmt.version}" distDir="${leansmt.distDir}"/>
    </target>
</project>
