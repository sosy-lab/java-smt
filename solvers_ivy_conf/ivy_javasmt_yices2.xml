<ivy-module version="2.0"
            xmlns:e="http://ant.apache.org/ivy/extra"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:noNamespaceSchemaLocation="http://ant.apache.org/ivy/schemas/ivy.xsd">
    <info organisation="org.sosy_lab" module="javasmt-yices2">
        <license name="Apache2 and GNU GPLv3" url="https://github.com/SRI-CSL/yices2/blob/master/LICENSE.txt"/>
        <description>
            JavaSMT components for the Yices2 solver.
            Separated from the main package of JavaSMT because of the licence.
        </description>
    </info>

    <configurations>
        <!-- default config, provides only x64 for backwards-compatibility -->
        <conf name="runtime" extends="runtime-x64"/>

        <!-- main configurations -->
        <conf name="runtime-x64" extends="runtime-linux-x64, runtime-windows-x64"/>
        <conf name="sources"/>
        <conf name="javadoc"/>
        <conf name="contrib"/>

        <!-- basic configurations -->
        <conf name="runtime-linux-x64" extends="runtime-common"/>
        <conf name="runtime-windows-x64" extends="runtime-common"/>

        <conf name="runtime-common" visibility="private"/>
    </configurations>

    <publications defaultconf="runtime">
        <artifact/>
        <artifact conf="sources" type="source" e:classifier="sources" ext="jar"/>
        <artifact conf="javadoc" type="javadoc" e:classifier="javadoc" ext="jar"/>
    </publications>

    <dependencies>
        <dependency org="org.sosy_lab" name="javasmt-solver-yices2" rev="2.7.0-4f83bf00e"
                    conf="runtime-linux-x64->solver-yices2-linux-x64; runtime-windows-x64->solver-yices2-windows-x64; contrib->sources,javadoc"/>

        <!-- keep the following dependencies synchronized with the default lib/ivy.xml and build-jar-yices2.xml -->

        <!-- SoSy-Lab Common Library -->
        <dependency org="org.sosy_lab" name="common" rev="0.3000-609-g90a352c"
                    conf="runtime-common->runtime; sources->sources"/>

        <!-- Google Core Libraries for Java
             Contains a lot of helpful data structures. -->
        <dependency org="com.google.guava" name="guava" rev="33.4.8-jre"
                    conf="runtime-common->default; sources->sources"/>

        <!-- Annotations we use for @Nullable etc. -->
        <dependency org="org.checkerframework" name="checker-qual" rev="3.51.0"
                    conf="runtime-common->default; sources->sources"/>
    </dependencies>

</ivy-module>
