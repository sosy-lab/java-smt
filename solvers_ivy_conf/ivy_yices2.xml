<ivy-module version="2.0"
    xmlns:e="http://ant.apache.org/ivy/extra"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://ant.apache.org/ivy/schemas/ivy.xsd">
    <info organisation="org.sosy_lab" module="javasmt-solver-yices2">
        <license name="GNU GPLv3" url="https://github.com/SRI-CSL/yices2/blob/master/LICENSE.txt"/>
        <description>
            Yices2 solver and the JavaSMT JNI wrapper.
        </description>
    </info>

    <configurations>
        <!-- default config, provides only x64 for backwards-compatibility -->
        <conf name="solver-yices2" extends="solver-yices2-x64"/>

        <!-- main configurations -->
        <conf name="solver-yices2-x64" extends="solver-yices2-linux-x64"/>

        <!-- basic configurations -->
        <conf name="solver-yices2-linux-x64" extends="solver-yices2-common"/>
        <conf name="solver-yices2-common" visibility="private"/>
    </configurations>

    <publications defaultconf="solver-yices2">
        <artifact name="libyices2java" conf="solver-yices2-linux-x64" e:arch="x64" type="shared-object" ext="so"/>
        <artifact name="yices" conf="solver-yices2-common" ext="jar"/>
    </publications>

    <dependencies></dependencies>

</ivy-module>
